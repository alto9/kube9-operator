# Example environment for local development (non-Docker).
# Copy to .env and load into your shell, or export variables manually.
# This application does not read .env files automatically; use shell exports,
# direnv, or similar so process.env is set before `npm run dev`.
#
# Cluster access: set KUBECONFIG to your kubeconfig path (e.g. kube9-localcluster
# out/kubeconfig, or any context that reaches the API—including kubectl proxy,
# SSH tunnels, or VPN). The operator uses @kubernetes/client-node loadFromDefault().

# Optional override — npm dev scripts default SERVER_URL when unset (see package.json)
# SERVER_URL=https://api.kube9.io

# Optional
LOG_LEVEL=info

# SQLite data directory; database file is {DB_PATH}/kube9.db
# Production default is /data. On a developer host use a writable path.
# npm run dev / dev:watch set DB_PATH to ./.kube9-data when unset.
# DB_PATH=.kube9-data

# Namespace for status ConfigMaps and health checks (Helm sets this in-cluster)
# POD_NAMESPACE=kube9-system

# HTTP port for /healthz, /readyz, /metrics (default 8080)
# HEALTH_PORT=8080
